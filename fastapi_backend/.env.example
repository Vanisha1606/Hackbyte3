# Google Gemini API key - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Which Gemini model to use (free-tier friendly options):
#   gemini-2.5-flash         (recommended)
#   gemini-2.5-flash-lite    (lighter, larger free quota)
#   gemini-flash-lite-latest (always points at newest -lite)
GEMINI_MODEL=gemini-2.5-flash

# Optional - point to a custom tesseract binary. Auto-detected by default.
# TESSERACT_CMD=/home/<you>/.local/bin/tesseract
